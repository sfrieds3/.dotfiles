{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "keybinds": {
    "command_list": "<leader>p",
    "editor_open": "ctrl+g",
    "input_move_down": "down,ctrl+n",
    "input_move_left": "left,ctrl+b",
    "input_move_right": "right,ctrl+f",
    "input_move_up": "up,ctrl+p",
    "messages_page_down": "pagedown,ctrl+alt+f,ctrl+d",
    "messages_page_up": "pageup,ctrl+alt+b,ctrl+u",
    "messages_next": "<leader>j",
    "messages_previous": "<leader>k",
    "tool_details": "<leader>o"
  }
}
